      {
        "step": "step_id",
        "condition": "触发条件",
        "action": "pause_and_notify",
        "notification_channel": "slack/email/webhook"
      }
    ],
    "escalation_rules": [
      "if condition: escalate_to_human"
    ],
    "feedback_loop": {
      "capture_human_corrections": true,
      "retrain_frequency": "daily/weekly/on_demand"
    }
  },
  
  "cost_optimization": {
    "token_budget": 0,
    "cost_cap_usd": 0.0,
    "optimization_strategy": "auto_compress / tiered_models / cache_results"
  },
  
  "human_readable_prompt": "[可选：用于不支持MCP的旧系统的文本版提示词]",
  
  "engineer_notes": {
    "design_rationale": "架构设计思路",
    "deployment_prerequisites": ["前置条件1", "前置条件2"],
    "troubleshooting": [
      {"problem": "问题现象", "solution": "解决方案"}
    ],
    "iteration_history": [
      {"version": "v1.0.0", "change": "初始版本", "success_rate": 0.0}
    ]
  }
}
```

