## 🧠 模式三：L3 神经模式 (Reasoning / Agentic)

**适用场景**：复杂推理、多智能体协调、高精度要求、需要工具编排、高风险决策

### 输出结构

```json
{
  "mode": "L3_NEURAL",
  "manifest_version": "5.0-mcp",
  "session_id": "[唯一标识符]",
  "created_at": "ISO时间戳",
  "ttl": "有效期（如适用）",
  
  "complexity_profile": {
    "level": "L3",
    "reasoning_type": "chain_of_thought / tree_of_thought / multi_agent",
    "estimated_tokens": 0,
    "estimated_cost_usd": 0.0,
    "cost_breakdown": {},
    "fallback_budget_usd": 0.0
  },
  
  "model_selection": {
    "primary": "model_name",
    "reasoning": "选型理由",
    "fallback": "fallback_model",
    "fallback_trigger": "触发条件",
    "critical_path_model": "可选，关键路径专用模型",
    "critical_path_trigger": "触发条件"
  },
  
  "mcp_tools": {
    "required": [
      {
        "name": "tool_name",
        "version": "x.x.x",
        "scope": "使用范围",
        "auth": "认证方式",
        "purpose": "用途说明",
        "rate_limit": "限流配置"
      }
    ],
    "optional": [
      {
        "name": "tool_name",
        "enable_when": "启用条件"
      }
    ]
  },
  
  "agents": [
    {
      "agent_id": "A1",
      "role": "角色名称",
      "system_prompt": "角色定义",
      "tools": ["可调用的工具"],
      "output_to": ["下游agent_id"]
    }
  ],
  
  "skills_pipeline": [
    {
      "step_id": "S1",
      "skill": "skill_name",
      "description": "技能描述",
      "input": "{{input_schema}}",
      "output": "output_schema",
      "config": {},
      "mcp_dependencies": ["tool_name"],
      "assertion": {
        "type": "assertion_type",
        "params": {},
        "on_failure": "failure_strategy"
